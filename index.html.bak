":"鳥取県","population":581309},{"id":32,"name":"島根県","population":795431},{"id":33,"name":"岡山県","population":1813508},{"id":34,"name":"広島県","population":2646324},{"id":35,"name":"山口県","population":1555006},{"id":36,"name":"徳島県","population":805372},{"id":37,"name":"香川県","population":961298},{"id":38,"name":"愛媛県","population":1464483},{"id":39,"name":"高知県","population":808948},{"id":40,"name":"福岡県","population":4292994},{"id":41,"name":"佐賀県","population":837568},{"id":42,"name":"長崎県","population":1570251},{"id":43,"name":"熊本県","population":1756086},{"id":44,"name":"大分県","population":1208570},{"id":45,"name":"宮崎県","population":1111623},{"id":46,"name":"鹿児島県","population":1723511},{"id":47,"name":"沖縄県","population":1042571}],"1970":[{"id":1,"name":"北海道","population":5184287},{"id":2,"name":"青森県","population":1427520},{"id":3,"name":"岩手県","population":1355447},{"id":4,"name":"宮城県","population":1819223},{"id":5,"name":"秋田県","population":1198897},{"id":6,"name":"山形県","population":1190367},{"id":7,"name":"福島県","population":1889813},{"id":8,"name":"茨城県","population":2143551},{"id":9,"name":"栃木県","population":1580007},{"id":10,"name":"群馬県","population":1658908},{"id":11,"name":"埼玉県","population":3866472},{"id":12,"name":"千葉県","population":3366624},{"id":13,"name":"東京都","population":11408071},{"id":14,"name":"神奈川県","population":5472247},{"id":15,"name":"新潟県","population":2325373},{"id":16,"name":"富山県","population":1029695},{"id":17,"name":"石川県","population":1002387},{"id":18,"name":"福井県","population":742511},{"id":19,"name":"山梨県","population":762029},{"id":20,"name":"長野県","population":1957457},{"id":21,"name":"岐阜県","population":1758954},{"id":22,"name":"静岡県","population":3089886},{"id":23,"name":"愛知県","population":5386163},{"id":24,"name":"三重県","population":1509177},{"id":25,"name":"滋賀県","population":889679},{"id":26,"name":"京都府","population":2250087},{"id":27,"name":"大阪府","population":7620480},{"id":28,"name":"兵庫県","population":4667928},{"id":29,"name":"奈良県","population":930198},{"id":30,"name":"和歌山県","population":1003463},{"id":31,"name":"鳥取県","population":568977},{"id":32,"name":"島根県","population":773575},{"id":33,"name":"岡山県","population":1707038},{"id":34,"name":"広島県","population":2496223},{"id":35,"name":"山口県","population":1511364},{"id":36,"name":"徳島県","population":791111},{"id":37,"name":"香川県","population":906660},{"id":38,"name":"愛媛県","population":1414436},{"id":39,"name":"高知県","population":786882},{"id":40,"name":"福岡県","population":3964696},{"id":41,"name":"佐賀県","population":820300},{"id":42,"name":"長崎県","population":1570778},{"id":43,"name":"熊本県","population":1723466},{"id":44,"name":"大分県","population":1198516},{"id":45,"name":"宮崎県","population":1051025},{"id":46,"name":"鹿児島県","population":1729007},{"id":47,"name":"沖縄県","population":945111}]};

    // ========== 定数 ==========
    const GEOJSON_URL = "https://raw.githubusercontent.com/dataofjapan/land/master/japan.geojson";
    const YEARS = Object.keys(POPULATION_DATA).sort((a, b) => +b - +a);
    const SVG_W = 960, SVG_H = 600;

    // ========== DOM要素 ==========
    const svg = d3.select("#map");
    const tooltip = document.getElementById("tooltip");
    const yearSelect = document.getElementById("yearSelect");

    // ========== 年選択UIの初期化 ==========
    YEARS.forEach(y => {
      const opt = document.createElement("option");
      opt.value = y;
      opt.textContent = y + "年";
      yearSelect.appendChild(opt);
    });
    yearSelect.value = YEARS[0]; // 最新年（2023）をデフォルト

    // ========== 投影法の設定 ==========
    const projection = d3.geoMercator()
      .center([137, 35.5])
      .scale(1600)
      .translate([SVG_W / 2, SVG_H / 2]);

    const path = d3.geoPath().projection(projection);

    // ========== カラースケール（全年一貫した最大値で固定） ==========
    const allPopulations = Object.values(POPULATION_DATA).flat().map(d => d.population);
    const globalMax = d3.max(allPopulations);
    const globalMin = 0;

    const colorScale = d3.scaleSequential()
      .domain([globalMin, globalMax])
      .interpolator(d3.interpolateBlues);

    // ========== 凡例の描画 ==========
    function drawLegend() {
      const legendSvg = d3.select("#legend");
      const legendW = 300, legendH = 20, offsetX = 30, offsetY = 15;

      const defs = legendSvg.append("defs");
      const linearGradient = defs.append("linearGradient")
        .attr("id", "legend-gradient")
        .attr("x1", "0%").attr("x2", "100%");

      const steps = 10;
      d3.range(steps + 1).forEach(i => {
        linearGradient.append("stop")
          .attr("offset", `${(i / steps * 100)}%`)
          .attr("stop-color", colorScale(globalMin + (globalMax - globalMin) * i / steps));
      });

      legendSvg.append("rect")
        .attr("x", offsetX).attr("y", offsetY)
        .attr("width", legendW).attr("height", legendH)
        .style("fill", "url(#legend-gradient)")
        .attr("rx", 3);

      // 目盛り
      const legendScale = d3.scaleLinear()
        .domain([0, globalMax / 10000])
        .range([offsetX, offsetX + legendW]);

      const tickValues = [0, 300, 600, 900, 1200, 1500];
      tickValues.forEach(v => {
        const x = legendScale(v);
        legendSvg.append("line")
          .attr("x1", x).attr("x2", x)
          .attr("y1", offsetY + legendH).attr("y2", offsetY + legendH + 4)
          .attr("stroke", "#aaa").attr("stroke-width", 1);
        legendSvg.append("text")
          .attr("x", x).attr("y", offsetY + legendH + 14)
          .attr("text-anchor", "middle")
          .attr("font-size", "10px")
          .attr("fill", "#aaa")
          .text(v === 0 ? "0" : v);
      });
    }

    // ========== ツールチップ ==========
    function showTooltip(event, name, population, year) {
      tooltip.innerHTML = `
        <div class="name">${name}</div>
        <div class="pop">人口: <strong>${population.toLocaleString()}</strong> 人</div>
        <div class="pop">（${year}年）</div>
      `;
      tooltip.style.opacity = "1";
      moveTooltip(event);
    }

    function moveTooltip(event) {
      const x = event.clientX + 14;
      const y = event.clientY - 10;
      tooltip.style.left = x + "px";
      tooltip.style.top = y + "px";
    }

    function hideTooltip() {
      tooltip.style.opacity = "0";
    }

    // ========== 地図の色更新 ==========
    function updateColors(year) {
      const yearData = POPULATION_DATA[year] || [];
      const popMap = new Map(yearData.map(d => [d.name, d.population]));

      svg.selectAll(".prefecture")
        .attr("fill", d => {
          const name = d.properties.nam_ja;
          const pop = popMap.get(name);
          return pop != null ? colorScale(pop) : "#333";
        })
        .on("mouseover", (event, d) => {
          const name = d.properties.nam_ja;
          const pop = popMap.get(name);
          if (pop != null) showTooltip(event, name, pop, year);
        })
        .on("mousemove", moveTooltip)
        .on("mouseout", hideTooltip);
    }

    // ========== GeoJSON読み込みと地図初期描画 ==========
    d3.json(GEOJSON_URL).then(geojson => {
      svg.selectAll(".prefecture")
        .data(geojson.features)
        .join("path")
        .attr("class", "prefecture")
        .attr("d", path)
        .attr("fill", "#333");

      drawLegend();
      updateColors(yearSelect.value);

      // 年変更イベント
      yearSelect.addEventListener("change", () => {
        updateColors(yearSelect.value);
      });

    }).catch(err => {
      console.error("GeoJSON読み込みエラー:", err);
      svg.append("text")
        .attr("x", SVG_W / 2).attr("y", SVG_H / 2)
        .attr("text-anchor", "middle")
        .attr("fill", "#ff6b6b")
        .attr("font-size", "16px")
        .text("地図データの読み込みに失敗しました。インターネット接続を確認してください。");
    });
  </script>
</body>
</html>